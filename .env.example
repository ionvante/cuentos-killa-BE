# ══════════════════════════════════════════════════════════
#  Variables de entorno para Railway
#  Configura estas en: Railway → tu proyecto → Variables
# ══════════════════════════════════════════════════════════

# ── Base de datos (Railway PostgreSQL) ──────────────────
# Railway las inyecta automáticamente si añades un plugin PostgreSQL
SPRING_DATASOURCE_URL=jdbc:postgresql://<host>:<port>/<db>
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=<tu-password>

# ── JWT ─────────────────────────────────────────────────
# Genera con: openssl rand -hex 32
JWT_SECRET=<genera-un-secreto-largo-y-aleatorio-minimo-64-chars>

# ── Firebase Admin SDK ──────────────────────────────────
# Opción A: Ruta al archivo JSON (si lo copias al contenedor)
FIREBASE_CREDENTIALS=firebase-adminsdk.json
# Opción B: Contenido del JSON como variable (recomendado en Railway)
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
FIREBASE_BUCKET=<tu-proyecto>.firebasestorage.app

# ── Correo (Gmail) ──────────────────────────────────────
SPRING_MAIL_USERNAME=tu-correo@gmail.com
SPRING_MAIL_PASSWORD=<app-password-de-gmail>

# ── MercadoPago ─────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=<tu-access-token>

# ── Sentry (opcional, monitoreo de errores) ─────────────
SENTRY_DSN=https://xxx@sentry.io/yyy

# ── CORS: dominios permitidos ───────────────────────────
# Añade tu dominio de Firebase Hosting aquí en application.yml
# cors.allowed-origins: https://tu-proyecto.web.app

# ── Puerto (Railway lo inyecta automáticamente) ─────────
# PORT=8080  ← Railway lo define solo, no es necesario configurarlo
